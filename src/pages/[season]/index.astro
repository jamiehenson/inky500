---
import ConstructorCard from "../../components/ConstructorCard.astro";
import Layout from "../../layouts/Layout.astro";
import type {
  ConstructorName,
  RacerName,
  SeasonName,
  TrackName,
} from "../../types";
import * as Icon from "@astropub/icons";
import { seasonRacers, drivers, tracks, results } from "@/data";
import type { SeasonRacerClass } from "@/data/seasonRacers";
import { carImages, withBase } from "@/utils";
import StatusBadge from "@/components/StatusBadge.astro";
import { Button } from "@/components/ui/button";
import { Image } from "astro:assets";

export function getStaticPaths() {
  return Object.keys(results).map((season) => ({ params: { season } }));
}

type Winner = {
  id: string;
  name: string;
  nationality?: string;
  team: string;
  car: ConstructorName;
  carClass?: SeasonRacerClass;
};

const CLASS_ORDER: SeasonRacerClass[] = ["gt3", "gt4", "tcx"];
const classLabelClass: Record<SeasonRacerClass, string> = {
  gt3: "bg-green-600 text-white",
  gt4: "bg-amber-500 text-black",
  tcx: "bg-blue-600 text-white",
  all: "bg-muted text-foreground",
};
const pointlessResults = ["DNF", "DSQ", "-"];

const { season } = Astro.params as { season: SeasonName };

// Multiclass seasons show a winner per class rather than an overall podium.
const isMulticlass = Object.values(seasonRacers[season]).some((r) => r?.class);

const toWinner = (id: RacerName, trackKey: string): Winner => {
  const racer = seasonRacers[season][id];
  return {
    id,
    name: drivers[id].name,
    nationality: drivers[id].countryCode,
    team: racer?.otherTeams?.[trackKey]?.team ?? racer?.team ?? "unknown",
    car: racer?.otherTeams?.[trackKey]?.car || racer?.car || "unknown",
    carClass: racer?.class,
  };
};

const tracksData = Object.entries(results[season]).map((track) => {
  const trackKey = track[0];
  const trackData = tracks[trackKey as TrackName];

  if (!track[1]?.results) {
    return {
      name: trackData?.name ?? "unknown",
      location: trackData?.location ?? "unknown",
      countryCode: trackData?.countryCode ?? "gb",
      date: track[1]?.date,
    };
  }

  const raceResults = track[1].results;
  const order = Object.keys(raceResults) as RacerName[];
  const finished = (id: RacerName) =>
    !pointlessResults.includes(raceResults[id] ?? "");

  // Per-class winner (first classified finisher in each class) for multiclass
  // seasons, otherwise the overall top three.
  const winners: Winner[] = isMulticlass
    ? CLASS_ORDER.map((cls) =>
        order.find((id) => seasonRacers[season][id]?.class === cls && finished(id)),
      )
        .filter((id): id is RacerName => Boolean(id))
        .map((id) => toWinner(id, trackKey))
    : order.slice(0, 3).map((id) => toWinner(id, trackKey));

  const themeCar = isMulticlass
    ? (winners.find((w) => w.carClass === "gt3")?.car ??
      winners[0]?.car ??
      "unknown")
    : (winners[0]?.car ?? "unknown");

  return {
    name: trackData?.name ?? "unknown",
    location: trackData?.location ?? "unknown",
    link: `/${season}/${trackKey}`,
    countryCode: trackData?.countryCode ?? "gb",
    winners,
    themeCar,
    date: track[1].date,
  };
});

const seasonNumber = parseInt(season.slice(1));
const seasonTitle = `Season ${seasonNumber.toString().toUpperCase()}`;
---

<Layout
  title={`Inky 500 | ${seasonTitle}`}
  description={`All the stats from ${seasonTitle} of the Inky 500 🔎`}
>
  <Button variant="outline" href={withBase()} class="absolute">
    <Icon.ChevronLeft size="24" aria-label="Back" />
    Seasons
  </Button>
  <div class="relative">
    {
      seasonNumber > 1 && (
        <a
          href={withBase(`/s${seasonNumber - 1}`)}
          class="absolute top-1/2 left-0 -translate-y-1/2 hidden sm:block"
        >
          <Button variant="outline">
            <Icon.ChevronLeft size="24" aria-label="Previous Season" />
            <span>S{seasonNumber - 1}</span>
          </Button>
        </a>
      )
    }
    <h1 class="flex items-center justify-center gap-6 mt-12">
      {seasonTitle}
    </h1>
    {
      seasonNumber < Object.keys(results).length && (
        <a
          href={withBase(`/s${seasonNumber + 1}`)}
          class="absolute top-1/2 right-0 -translate-y-1/2 hidden sm:block"
        >
          <Button variant="outline">
            <span>S{seasonNumber + 1}</span>
            <Icon.ChevronRight size="24" aria-label="Next Season" />
          </Button>
        </a>
      )
    }
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {
      tracksData.map(
        (track, index) =>
          track && (
            <ConstructorCard
              title={track.name}
              index={index + 1}
              subtitle={[track.location, track.countryCode]}
              link={track.link}
              car={track.themeCar ?? "unknown"}
            >
              <div class="flex flex-col gap-2 mb-6">
                {track.winners?.map((winner, index) => (
                  <p class="flex justify-between gap-3">
                    <span class="flex items-center gap-1">
                      {winner.carClass ? (
                        <span
                          class={`uppercase text-xs font-bold rounded px-1.5 py-0.5 ${classLabelClass[winner.carClass]}`}
                        >
                          {winner.carClass}
                        </span>
                      ) : index === 0 ? (
                        "🥇"
                      ) : index === 1 ? (
                        "🥈"
                      ) : (
                        "🥉"
                      )}
                      {winner.name}
                    </span>
                    <span class="flex items-center gap-2 text-xs text-right">
                      {winner.team}
                      <Image
                        src={carImages[winner.car as ConstructorName]}
                        alt={winner.car ?? "unknown"}
                        class="w-6 h-6 inline-block"
                        loading="eager"
                      />
                    </span>
                  </p>
                ))}
              </div>
              <StatusBadge
                status={track.winners ? "complete" : "upcoming"}
                date={track.date}
              />
            </ConstructorCard>
          )
      )
    }
  </div>
</Layout>
